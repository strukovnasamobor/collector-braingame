# Google OAuth 2.0 Web Client ID (Firebase Auth -> Google Sign-In -> Web SDK config).
# Find it in Google Cloud Console -> APIs & Services -> Credentials ->
# "Web client (auto created by Google Service)" -> Client ID.
# Format: NNNNNNNNNNNN-xxxxxxxxxxxxxxxx.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID=

# Cloudflare Worker base URL (matchmaking / game validation backend).
# Defaults to http://127.0.0.1:8787 when unset.
VITE_BACKEND_URL=
